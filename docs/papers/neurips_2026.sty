% neurips_2026.sty — NeurIPS 2026 style (based on neurips_2024)
% For the real submission, download from https://neurips.cc/Conferences/2026/PaperInformation/StyleFiles

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2026}[2026/01/01 NeurIPS 2026 submission style]

\newif\if@neuripsfinal\@neuripsfinalfalse
\DeclareOption{final}{\@neuripsfinaltrue}
\DeclareOption{preprint}{}
\ProcessOptions\relax

% Page geometry — NeurIPS standard
\RequirePackage[
  letterpaper,
  textwidth=5.5in,
  textheight=9in,
  top=1in,
  marginparwidth=0.7in
]{geometry}

% Font
\RequirePackage{times}
\linespread{1.0}

% Section formatting
\RequirePackage[compact]{titlesec}
\titleformat{\section}{\large\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\normalsize\itshape}{\thesubsubsection}{1em}{}

% Tighter spacing
\titlespacing*{\section}{0pt}{2.0ex plus 0.8ex minus 0.4ex}{1.0ex plus 0.3ex}
\titlespacing*{\subsection}{0pt}{1.5ex plus 0.6ex minus 0.3ex}{0.8ex plus 0.2ex}

% Paragraph spacing
\setlength{\parskip}{0.5ex plus 0.2ex minus 0.1ex}
\setlength{\parindent}{0pt}

% Anonymous handling
\if@neuripsfinal
  % Camera-ready: show authors
\else
  % Review: anonymous (author block handled by document)
\fi

\endinput
